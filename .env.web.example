# DeepBot Web 服务器环境变量配置

# 服务器端口
PORT=3008

# 运行环境（development | production）
NODE_ENV=production

# 访问密码（可选，留空则无需密码）
# 设置后，客户端需要使用此密码登录获取 Token
ACCESS_PASSWORD=

# JWT 密钥（必须设置，用于生成和验证 Token）
# 生产环境请使用强随机字符串
JWT_SECRET=your-jwt-secret-change-in-production

# 通义千问 API 配置（可选，也可以通过 API 配置）
QWEN_API_KEY=
QWEN_MODEL=qwen-max

# 数据目录（可选，默认 ~/.deepbot）
DATA_DIR=
